{
  "kind": "collectionType",
  "collectionName": "courses",
  "info": {
    "singularName": "course",
    "pluralName": "courses",
    "displayName": "Course"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "text",
      "maxLength": 150,
      "required": true,
      "unique": true
    },
    "description": {
      "type": "blocks",
      "required": true
    },
    "published_status": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "created_time": {
      "type": "datetime",
      "required": true
    },
    "updated_time": {
      "type": "datetime",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "required": true,
      "default": "Technology",
      "enum": [
        "Technology",
        "Business",
        "Soft_skill"
      ]
    },
    "thumbnail": {
      "type": "text",
      "minLength": 1,
      "required": true
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 1
    }
  }
}
